.geist-container.inline { display: inline-flex; }

.geist-wrapper { max-width: 100%; width: var(--geist-page-width-with-margin); padding-left: var(--geist-page-margin); padding-right: var(--geist-page-margin); margin-left: auto; margin-right: auto; }

