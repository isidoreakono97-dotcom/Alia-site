  .geist-container.lg-row { flex-flow: wrap; }
  .geist-container:not(.lg-row) > .geist-container { margin-top: 0px; }
  .geist-container:not(.lg-row) > .geist-container ~ .geist-container { margin-top: calc(var(--geist-gap) * var(--gap-ratio)); }
