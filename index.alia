<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ALIA Construction Services</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', Arial, sans-serif;
      color: #333;
      line-height: 1.6;
      background: #fff;
    }
    header {
      background: linear-gradient(135deg, #0a1f44 0%, #1a3a5f 100%);
      color: white;
      text-align: center;
      padding: 50px 20px;
    }
    header img {
      max-width: 120px;
      margin-bottom: 15px;
    }
    header h1 {
      font-size: 2.5em;
      color: #f4b400;
      letter-spacing: 2px;
    }
    header p {
      font-size: 1.2em;
      margin-top: 10px;
      font-style: italic;
    }
    section {
      padding: 50px 20px;
      max-width: 1100px;
      margin: auto;
    }
    h2 {
      color: #0a1f44;
      margin-bottom: 20px;
      text-align: center;
      font-size: 2em;
    }
    .services {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
    }
    .service {
      background: #f5f5f5;
      padding: 25px;
      border-radius: 10px;
      border-left: 5px solid #f4b400;
    }
    .service h3 {
      color: #0a1f44;
      margin-bottom: 10px;
    }
    .values {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 15px;
      text-align: center;
      margin-top: 30px;
    }
    .value {
      background: #0a1f44;
      color: white;
      padding: 20px;
      border-radius: 8px;
    }
    .gallery {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 20px;
      margin-top: 30px;
    }
    .gallery img {
      width: 100%;
      border-radius: 10px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    }
    .contact {
      background: #f5f5f5;
      padding: 40px 20px;
      text-align: center;
      border-radius: 10px;
    }
    .contact p {
      margin: 10px 0;
      font-size: 1.1em;
    }
    footer {
      background: #0a1f44;
      color: white;
      text-align: center;
      padding: 25px;
      margin-top: 50px;
    }
    .btn-contact {
      display: inline-block;
      background: #f4b400;
      color: #0a1f44;
      padding: 15px 30px;
      text-decoration: none;
      border-radius: 5px;
      font-weight: bold;
      margin-top: 20px;
    }
    .btn-contact:hover {
      background: #ffc107;
    }
  </style>
</head>
<body>

  <header>
    <h1>ALIA CONSTRUCTION SERVICES</h1>
    <p>BÂTIR AUJOURD'HUI, VALORISER DEMAIN</p>
  </header>

  <section>
    <h2>EXPERTISE – QUALITÉ – ENGAGEMENT</h2>
    <p style="text-align:center; font-size:1.2em;">Des solutions durables pour des réalisations d'exception</p>
    
    <div class="gallery">
      <img src="attachment://0" alt="Projet ALIA Construction">
      <img src="attachment://1" alt="Tenue ALIA Construction">
      <img src="attachment://2" alt="Carte de visite ALIA Construction">
    </div>
  </section>

  <section>
    <h2>NOS SERVICES</h2>
    <div class="services">
      <div class="service">
        <h3>Construction Générale</h3>
        <p>Maisons, bâtiments, travaux neufs</p>
      </div>
      <div class="service">
        <h3>Études & Conception</h3>
        <p>Plans architecturaux et techniques</p>
      </div>
      <div class="service">
        <h3>Suivi & Gestion de Chantier</h3>
        <p>Supervision complète de vos projets</p>
      </div>
      <div class="service">
        <h3>Rénovation & Finitions</h3>
        <p>Remise à neuf et finitions haut de gamme</p>
      </div>
      <div class="service">
        <h3>Gestion de Projet</h3>
        <p>Coordination et pilotage de A à Z</p>
      </div>
      <div class="service">
        <h3>Études Géotechnique & Topographique</h3>
        <p>Analyses de sol et relevés terrain</p>
      </div>
    </div>
  </section>

  <section>
    <h2>NOS VALEURS</h2>
    <div class="values">
      <div class="value">ÉQUIPE EXPÉRIMENTÉE</div>
      <div class="value">QUALITÉ GARANTIE</div>
      <div class="value">ENGAGEMENT & FIABILITÉ</div>
      <div class="value">SATISFACTION CLIENT</div>
    </div>
  </section>

  <section>
    <div class="contact">
      <h2>CONTACTEZ-NOUS</h2>
      <p><strong>Téléphone :</strong> 655 51 15 43 / 651 33 48 47</p>
      <p><strong>Email :</strong> isiDOREAKONO97@gmail.com</p>
      <p><strong>Adresse :</strong> Yaoundé, Cameroun</p>
      <p><strong>Facebook :</strong> Alia Construction Services</p>
      <a href="tel:655511543" class="btn-contact">APPELER MAINTENANT</a>
    </div>
  </section>

  <footer>
    <p>CONSTRUCTION – RÉNOVATION – INNOVATION POUR UN AVENIR MEILLEUR</p>
    <p style="margin-top:10px;">© 2026 ALIA Construction Services - Tous droits réservés</p>
  </footer>

</body>
</html>
